# KYC demat / CMR proofs — allow images & PDF, block scripts
<IfModule mod_authz_core.c>
  Require all granted
</IfModule>
<FilesMatch "\.(php|phtml|php3|php4|php5|phps|cgi|pl|asp|aspx)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>
Options -Indexes

<IfModule mod_headers.c>
  Header set Cache-Control "private, max-age=3600"
</IfModule>
