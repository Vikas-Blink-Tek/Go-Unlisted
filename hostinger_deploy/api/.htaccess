# Protect config files from direct web access
<Files "db_config.php">
    Order allow,deny
    Deny from all
</Files>
<Files "mail_config.php">
    Order allow,deny
    Deny from all
</Files>
<Files "deploy.config.php">
    Order allow,deny
    Deny from all
</Files>

# Block error logs from web access
<FilesMatch "\.(log)$">
    Require all denied
</FilesMatch>
